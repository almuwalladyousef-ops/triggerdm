PAGE_ACCESS_TOKEN=       # Meta page access token (long-lived)
PAGE_ID=                 # Instagram Page ID
APP_SECRET=              # Meta app secret (for webhook signature verification)
VERIFY_TOKEN=            # Any string you choose — used in Meta webhook setup
GOOGLE_DRIVE_FILE_ID=    # ID of the db.json file in Google Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=      # Full key including -----BEGIN----- and \n characters
CRON_SECRET=             # Secret header to protect /api/refresh-token
ADMIN_SECRET=            # Password to access the dashboard
